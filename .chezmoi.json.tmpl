{
  "encryption": "age",
  "age": {
    "identity": "~/.config/chezmoi/key.txt",
    "recipient": {{ promptStringOnce . "ageRecipient" "Age public key (run: age-keygen -y ~/.config/chezmoi/key.txt)" | quote }}
  },
  "data": {
    "name": {{ promptString "What is your name" | quote }},
    "email": {{ promptString "What is your email" | quote }},
    "profile": {{ promptChoice "What type of setup do you want" (list "personal" "work") | quote }},
    "setSshKey": {{ promptBool "Do you want to set up an SSH key" }},
    "gitSigningKeyName": "id_github",
    "hasGitlabAccess": {{ promptBool "Do you have GitLab access" }}
  }
}
